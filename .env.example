# ============================================================
# SmartCycle (金仕达·智循) — Environment Variables Template
# ============================================================
# Copy to backend/.env and fill in your values.
# The backend auto-loads backend/.env at startup.
# ============================================================

# --- LLM / AI ---
# SmartCycle supports any OpenAI-compatible API:
#   • DeepSeek:  https://api.deepseek.com/v1       (model: deepseek-chat / deepseek-v4-pro)
#   • Zhipu GLM: https://open.bigmodel.cn/api/paas/v4   (model: glm-4-flash)
#   • Qwen:      https://dashscope.aliyuncs.com/compatible-mode/v1  (model: qwen-plus)
#   • OpenAI:    https://api.openai.com/v1          (model: gpt-4o)
# Leave LLM_API_KEY blank to use template-based mock LLM (offline mode).
LLM_API_KEY=sk-your-key-here
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=2048
LLM_TIMEOUT=45

# --- Embeddings ---
# Model used by the RAG pipeline for document embeddings.
# Falls back to deterministic hash-based mock if sentence-transformers unavailable.
EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5
EMBEDDING_DIM=384

# --- Database (PostgreSQL + pgvector) ---
# Used when running with Docker Compose.
# For local dev without Docker, these are optional (pipeline runs in-memory).
DB_HOST=localhost
DB_USER=smartcycle
DB_PASS=smartcycle
DB_NAME=smartcycle
DB_PORT=5432

# --- Market Data ---
# Set to "false" to use mock data only (offline mode).
# Real data sources: akshare (A-shares), yfinance (US stocks).
MARKET_DATA_ENABLED=true
MARKET_DATA_TIMEOUT=8

# --- Web Search ---
# DuckDuckGo free Instant Answer API — no API key required.
# Set to "false" to disable web search.
WEB_SEARCH_ENABLED=true
WEB_SEARCH_TIMEOUT=8

# --- Compliance ---
# Maximum retries for the compliance gatekeeper loop-back.
# When the Empathy Copilot's output fails compliance, it is sent back
# for revision up to this many times before force-override kicks in.
COMPLIANCE_MAX_RETRIES=3

# --- Redis (Cache & Session) ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- ChromaDB (Vector Store) ---
CHROMA_HOST=localhost
CHROMA_PORT=8001

# --- Auth ---
# Change this to a long random string in production!
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# --- Demo User (for development) ---
DEMO_USERNAME=admin
DEMO_PASSWORD=smartcycle2024

# --- App ---
FRONTEND_PORT=3000
BACKEND_PORT=8000
ENVIRONMENT=development
LOG_LEVEL=DEBUG
