# ============================================================
# SmartCycle — Environment Variables Template
# Copy to .env and fill in your values.
# ============================================================

# --- LLM / AI ---
# SmartCycle supports any OpenAI-compatible API:
#   • DeepSeek:  https://api.deepseek.com/v1  (model: deepseek-chat)
#   • Zhipu GLM: https://open.bigmodel.cn/api/paas/v4  (model: glm-4-flash)
#   • Qwen:      https://dashscope.aliyuncs.com/compatible-mode/v1  (model: qwen-plus)
#   • OpenAI:    https://api.openai.com/v1  (model: gpt-4o)
LLM_API_KEY=sk-your-key-here
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=2048
LLM_TIMEOUT=45
EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5

# --- Database ---
DB_USER=smartcycle
DB_PASS=smartcycle
DB_NAME=smartcycle
DB_PORT=5432

# --- Market Data ---
# Set to "false" to use mock data only (offline mode)
MARKET_DATA_ENABLED=true
MARKET_DATA_TIMEOUT=8

# --- Web Search ---
# DuckDuckGo free API — no API key required
WEB_SEARCH_ENABLED=true
WEB_SEARCH_TIMEOUT=8

# --- Redis ---
REDIS_PORT=6379

# --- ChromaDB ---
CHROMA_PORT=8001

# --- App ---
FRONTEND_PORT=3000
BACKEND_PORT=8000
JWT_SECRET=change-me-in-production-use-a-long-random-string
ENVIRONMENT=development
LOG_LEVEL=DEBUG
